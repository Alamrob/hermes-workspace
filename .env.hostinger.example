# Hermes Workspace on Hostinger Node.js
# Copy values into the Hostinger Node.js app environment panel.

NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Required for any public/non-loopback deployment.
# Use a unique 32+ character secret in Hostinger. Do not commit the real value.
HERMES_PASSWORD=replace-with-a-strong-32-character-secret

# Hostinger terminates HTTPS in front of the Node.js process.
COOKIE_SECURE=1
TRUST_PROXY=1

# Full Hermes Agent mode:
# Use these when Hermes Agent gateway and dashboard run on a separate VPS/service.
# HERMES_API_URL=https://agent-gateway.example.com
# HERMES_DASHBOARD_URL=https://agent-dashboard.example.com
# HERMES_API_TOKEN=replace-with-the-gateway-api-server-key

# Portable OpenAI-compatible mode:
# Use this when you only have an OpenAI-compatible chat backend.
# Advanced panes such as sessions, memory, skills, jobs, and dashboard features
# may remain unavailable without HERMES_DASHBOARD_URL.
# HERMES_API_URL=https://openai-compatible.example.com
